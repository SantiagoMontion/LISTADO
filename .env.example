# Copiá este archivo como .env en local (no subir .env al repo).
# En Vercel: Project → Settings → Environment Variables (mismos nombres).

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_clave_anon_publica

# Web Push (avisos de tarea en el celular). Generar par: npx web-push generate-vapid-keys
# La pública va aquí y en Vercel; la privada solo en Supabase Edge Function secrets.
VITE_VAPID_PUBLIC_KEY=

# Dominio de la tienda Shopify (para botón «Ver orden» en tareas)
# Opción A (recomendada): handle en admin.shopify.com/store/{handle}
# VITE_SHOPIFY_STORE_HANDLE=notmid
# Opción B: dominio myshopify
# VITE_SHOPIFY_STORE_DOMAIN=notmid.myshopify.com


# Logística Andreani — VERCEL (producción, server-side, NO VITE_)
# ANDREANI_API_URL=https://tu-servicio.up.railway.app
# ANDREANI_API_KEY=misma_clave_que_railway
# El frontend usa proxy /api → Railway (sin CORS). No hace falta VITE_ANDREANI_* en prod.
# Desactivá "Sign ups" públicos para que nadie se registre solo.
# Sesión larga: Dashboard → Authentication → Sessions (JWT / refresh; revisá la doc vigente de Supabase).
