{
  "rewrites": [
    {
      "source": "/api/logistics/:path*",
      "destination": "/api/andreani/logistics/:path*"
    },
    {
      "source": "/api/shopify/:path*",
      "destination": "/api/andreani/shopify/:path*"
    },
    {
      "source": "/api/health",
      "destination": "/api/andreani/health"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
